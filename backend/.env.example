# ====================================================================
# Antigravity RAG Environment Configuration Template
# Duplicate this file as '.env' in the same folder and set your credentials.
# ====================================================================

# Google Gemini API Configuration (Model & Embeddings)
# Get your API key here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Configuration (Fallback option)
OPENAI_API_KEY=your_openai_api_key_here

# Langfuse Observability API Credentials
# Get your credentials here: https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=lf-pub-...
LANGFUSE_SECRET_KEY=lf-sec-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Vector Database Path (For Persistent ChromaDB storage)
CHROMA_PERSIST_DIR=./chroma_db

# Pipeline Ingestion Parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=4
